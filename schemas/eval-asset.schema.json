{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/eval-asset.schema.json",
  "title": "SDD Harness Eval Asset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "eval_id",
    "check"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "eval_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "check": {
      "oneOf": [
        {
          "$ref": "#/$defs/command_check"
        },
        {
          "$ref": "#/$defs/file_exists_check"
        },
        {
          "$ref": "#/$defs/json_field_check"
        },
        {
          "$ref": "#/$defs/no_out_of_scope_changes_check"
        },
        {
          "$ref": "#/$defs/api_scenario_check"
        }
      ]
    }
  },
  "$defs": {
    "command_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "type",
        "command"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "command"
        },
        "description": {
          "type": "string"
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "file_exists_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "type",
        "path"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "file_exists"
        },
        "description": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "json_field_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "type",
        "path",
        "json_pointer",
        "expected"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "json_field"
        },
        "description": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "json_pointer": {
          "type": "string",
          "minLength": 1
        },
        "expected": {}
      }
    },
    "no_out_of_scope_changes_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "type"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "no_out_of_scope_changes"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "api_scenario_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "type",
        "method",
        "url",
        "expected_status"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "api_scenario"
        },
        "description": {
          "type": "string"
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "request_json": {},
        "expected_status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "response_json_pointer": {
          "type": "string"
        },
        "expected_json": {}
      }
    }
  }
}
