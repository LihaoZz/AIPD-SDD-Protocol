{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/project-memory.schema.json",
  "title": "SDD Harness Project Memory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "completed_mbs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "completed_mbs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mb_id",
          "parent_fb_id",
          "result",
          "validated_evidence",
          "key_decisions",
          "pattern_type",
          "applicability",
          "recorded_at",
          "timezone_name"
        ],
        "properties": {
          "mb_id": {
            "type": "string",
            "minLength": 1
          },
          "parent_fb_id": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "passed"
            ]
          },
          "validated_evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "key_decisions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reusable_notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "pattern_type": {
            "type": "string",
            "minLength": 1
          },
          "applicability": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "mb_ids",
              "parent_fb_ids"
            ],
            "properties": {
              "mb_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "parent_fb_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "notes": {
                "type": "string"
              }
            }
          },
          "recorded_at": {
            "type": "string",
            "minLength": 1
          },
          "timezone_name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
