{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/failure-log.schema.json",
  "title": "SDD Harness Failure Log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "failures"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mb_id",
          "attempt_id",
          "failure_type",
          "condition",
          "attempted_fix",
          "result"
        ],
        "properties": {
          "mb_id": {
            "type": "string",
            "minLength": 1
          },
          "attempt_id": {
            "type": "string",
            "minLength": 1
          },
          "failure_type": {
            "type": "string",
            "minLength": 1
          },
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "attempted_fix": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
