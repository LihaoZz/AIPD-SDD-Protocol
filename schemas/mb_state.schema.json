{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/mb-state.schema.json",
  "title": "SDD Harness MB State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mb_id",
    "status",
    "retry_count",
    "last_attempt_id",
    "last_verification_report_path",
    "last_verification_digest",
    "last_failure_reason",
    "last_failure_issue_type",
    "autonomy_level",
    "approval_status",
    "review_required",
    "next_action",
    "provider_attempt_counts",
    "provider_failure_counts",
    "last_execution_provider",
    "updated_at",
    "timezone_name"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "mb_id": {
      "type": "string",
      "pattern": "^fb[0-9]+-mb[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "running",
        "verifying",
        "passed",
        "failed",
        "blocked",
        "routed_to_recovery"
      ]
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "last_attempt_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_verification_report_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_verification_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_failure_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_failure_issue_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "spec_gap",
        "implementation_bug",
        "quality_evidence_gap",
        "state_drift",
        "environment_issue",
        "review_context_gap",
        null
      ]
    },
    "autonomy_level": {
      "type": "string",
      "enum": [
        "L1_human_approval",
        "L2_auto_with_review",
        "L3_full_auto"
      ]
    },
    "approval_status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "not_required"
      ]
    },
    "review_required": {
      "type": "boolean"
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "provider_attempt_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codex",
        "minimax"
      ],
      "properties": {
        "codex": {
          "type": "integer",
          "minimum": 0
        },
        "minimax": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "provider_failure_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codex",
        "minimax"
      ],
      "properties": {
        "codex": {
          "type": "integer",
          "minimum": 0
        },
        "minimax": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "last_execution_provider": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "codex",
        "minimax",
        null
      ]
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "timezone_name": {
      "type": "string",
      "minLength": 1
    }
  }
}
