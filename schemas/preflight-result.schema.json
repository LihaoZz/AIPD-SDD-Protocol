{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/preflight-result.schema.json",
  "title": "SDD Harness Preflight Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "level",
    "project_root",
    "result",
    "summary",
    "missing_items",
    "blocking_items",
    "checks",
    "generated_at",
    "timezone_name"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "level": {
      "type": "string",
      "enum": [
        "session",
        "mb"
      ]
    },
    "project_root": {
      "type": "string",
      "minLength": 1
    },
    "mb_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "ready",
        "bootstrap_required",
        "blocked"
      ]
    },
    "autonomy_decision": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "missing_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocking_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "detail"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "timezone_name": {
      "type": "string",
      "minLength": 1
    }
  }
}
